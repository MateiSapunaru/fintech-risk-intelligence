# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Environment and local config
.env
.env.*
!.env.example
.python-version

# Editors and OS files
.vscode/
.idea/
Thumbs.db
.DS_Store

# Build artifacts
build/
dist/
*.egg-info/

# Logs
*.log

# Local generated data we do not want in Git
data/processed/*
!data/processed/.gitkeep
